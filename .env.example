# ---------------------------------------------------------
# 🌐 API
# ---------------------------------------------------------
# Server-side (RSC + server actions + middleware) — must reach the backend
API_URL=http://localhost:5000

# Browser-side — only used if the client ever calls the API directly
NEXT_PUBLIC_API_URL=http://localhost:5000

# ---------------------------------------------------------
# 🔐 Admin cookies (httpOnly, set by Next.js server actions)
# ---------------------------------------------------------
# Lifetime of the admin access cookie (mirrors backend JWT_ACCESS_SECRET_EXPIRES_IN)
ADMIN_ACCESS_COOKIE_MAX_AGE_SECONDS=86400
